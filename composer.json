{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "streetmesh/story-engine",
    "description": "StoryEngine: a three-agent ensemble (Director, Choreographer, Chronicler) that animates StreetMesh Places with game, training, and concierge modes.",
    "type": "library",
    "license": "MIT",
    "keywords": ["streetmesh", "story", "narrative", "ai", "laravel", "metaverse"],
    "authors": [
        {
            "name": "StreetMesh",
            "email": "hello@streetmesh.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/contracts": "^13.0",
        "illuminate/support": "^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^11.0",
        "phpunit/phpunit": "^12.0"
    },
    "autoload": {
        "psr-4": {
            "StreetMesh\\StoryEngine\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "StreetMesh\\StoryEngine\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "StreetMesh\\StoryEngine\\StoryEngineServiceProvider"
            ],
            "aliases": {
                "Story": "StreetMesh\\StoryEngine\\Facades\\Story"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
